<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "mybatis-3-mapper.dtd" >
<mapper namespace="me._hanho.nextjs_shop.file.FileMapper">
	<select id="getFile">
		SELECT * 
		FROM nextjs_shop_file
		WHERE file_id = #{fileId}
	</select>

	<insert id="insertFile" parameterType="FileUploadRequest"
		useGeneratedKeys="true" keyProperty="fileId" keyColumn="file_id">
		INSERT INTO nextjs_shop_file (file_name, store_name, file_extension, file_path)
		VALUES (#{fileName}, #{storeName}, #{fileExtension}, #{filePath})
	</insert>
</mapper>
